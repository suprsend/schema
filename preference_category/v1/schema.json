{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schema.suprsend.com/preference_category/v1/schema.json",
    "title": "PreferenceCategorySchemaV1",
    "description": "Preference Category Schema v1",
    "$comment": "Preference Category Schema v1",
    "type": "object",
    "properties": {
      "$schema": {
        "type": "string",
        "format": "uri",
        "default": "https://schema.suprsend.com/preference_category/v1/schema.json"
      },
      "root_categories": {
        "type": "array",
        "uniqueItems": true,
        "description": "entries with respect to each root category and their sections & categories",
        "items": {
          "$ref": "https://schema.suprsend.com/preference_category/v1/schema.json#/$definitions/root_category_def"
        },
        "minItems": 3,
        "maxItems": 3
      },
      "status": {
        "type": ["string", "null"],
        "enum": ["draft", "active", "inactive"],
        "description": "Status of the preference category, read only"
      },
      "hash": {
        "type": ["string", "null"],
        "maxLength": 256,
        "description": "hash of the preference category, read only"
      },
      "version_no": {
        "type": ["integer", "null"],
        "description": "Version number of the preference category, read only"
      },
      "commit_message": {
        "type": ["string", "null"],
        "description": "Commit message. read only"
      },
      "committed_at": {
        "type": ["string", "null"],
        "description": "Commit timestamp. read only"
      }
    },
    "required": ["root_categories"],
    "additionalProperties": true,
    "$definitions": {
      "root_category_def": {
        "type": "object",
        "properties": {
          "root_category": {
            "type": "string",
            "enum": ["system", "transactional", "promotional"],
            "description": "Root category"
          },
          "sections": {
            "type": ["array", "null"],
            "description": "Array of sections in the root category",
            "items": {
              "$ref": "https://schema.suprsend.com/preference_category/v1/schema.json#/$definitions/section_def"
            },
            "maxItems": 25
          }
        },
        "required": ["root_category"],
        "additionalProperties": true
      },
      "section_def": {
        "type": "object",
        "properties": {
          "name": {
            "type": ["string", "null"],
            "description": "Section name"
          },
          "description": {
            "type": ["string", "null"],
            "description": "Section description"
          },
          "tags": {
            "type": ["array", "null"],
            "uniqueItems": true,
            "description": "Section tags",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[a-z0-9_\\-.:]+$"
            },
            "maxItems": 25
          },
          "categories": {
            "type": ["array", "null"],
            "description": "Array of categories in the section",
            "items": {
              "$ref": "https://schema.suprsend.com/preference_category/v1/schema.json#/$definitions/category_def"
            },
            "maxItems": 100
          }
        },
        "required": [],
        "additionalProperties": true
      },
      "category_def": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "category name",
            "minLength": 1,
            "maxLength": 128
          },
          "description": {
            "type": ["string", "null"],
            "description": "category description"
          },
          "category": {
            "type": ["string", "null"],
            "description": "this is the slug derived from the name. this is used to identify the category, read only",
            "maxLength": 128
          },
          "default_preference": {
            "type": "string",
            "enum": ["cant_unsubscribe", "opt_in", "opt_out"],
            "description": "Category default preference"
          },
          "default_mandatory_channels": {
            "type": ["array", "null"],
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "sms",
                "email",
                "androidpush",
                "iospush",
                "webpush",
                "inbox",
                "whatsapp",
                "slack",
                "ms_teams"
              ]
            },
            "description": "If default preference is cant_unsubscribe, this is the mandatory channels that cant be unsubscribed. If null, it means all channels are unsubscribable."
          },
          "default_opt_in_channels": {
            "type": ["array", "null"],
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "sms",
                "email",
                "androidpush",
                "iospush",
                "webpush",
                "inbox",
                "whatsapp",
                "slack",
                "ms_teams"
              ]
            },
            "description": "If default preference is cant_unsubscribe/opt_in, this is the default channels that will be initially opted-in (on top of mandatory-channels in case of cant_unsubscribe). If null, it means all channels are opted-in."
          },
          "tags": {
            "type": ["array", "null"],
            "uniqueItems": true,
            "description": "Category tags",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[a-z0-9_\\-.:]+$"
            },
            "maxItems": 25
          },
          "digest_schedule": {
            "oneOf": [
              { "type": "null" },
              {
                "$ref": "#/$definitions/digest_schedule_def"
              }
            ],
            "description": "Digest schedule config for the category. If null, digest is not configured."
          },
          "properties": {
            "type": ["array", "null"],
            "description": "Properties defined at the category. If null, no properties are configured.",
            "maxItems": 5,
            "items": {
              "$ref": "#/$definitions/cat_property_def"
            }
          }
        },
        "required": ["name", "default_preference"],
        "additionalProperties": true
      },
      "digest_schedule_def": {
        "type": "object",
        "description": "Digest schedule config for the category",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether digest schedule is enabled for this category"
          },
          "options": {
            "type": "array",
            "description": "Available digest schedule options. Exactly one option must have is_default=true.",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "$ref": "#/$definitions/digest_schedule_option_def"
            }
          }
        },
        "required": ["enabled", "options"],
        "additionalProperties": true
      },
      "digest_schedule_option_def": {
        "type": "object",
        "description": "DigestSchedule Option Definition",
        "properties": {
          "id": {
            "type": "string",
            "description": "Slug identifying the option. Auto-derived from label when omitted.",
            "maxLength": 64,
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "label": {
            "type": "string",
            "description": "Human-readable label for the option",
            "minLength": 1,
            "maxLength": 256
          },
          "frequency": {
            "type": "string",
            "description": "Digest frequency",
            "enum": [
              "instantly",
              "minutely",
              "hourly",
              "daily",
              "weekly_mo2fr",
              "weekly",
              "monthly"
            ]
          },
          "interval": {
            "type": ["integer", "null"],
            "description": "Repeat interval for the frequency (defaults to 1)",
            "minimum": 0
          },
          "time": {
            "oneOf": [
              { "type": "null" },
              {
                "$ref": "#/$definitions/digest_field_config_string_def"
              }
            ],
            "description": "Time-of-day config (HH:MM)"
          },
          "weekdays": {
            "oneOf": [
              { "type": "null" },
              {
                "$ref": "#/$definitions/digest_field_config_weekdays_def"
              }
            ],
            "description": "Weekdays config (used for weekly/weekly_mo2fr)"
          },
          "monthdays": {
            "oneOf": [
              { "type": "null" },
              {
                "$ref": "#/$definitions/digest_field_config_monthdays_def"
              }
            ],
            "description": "Monthdays config (used for monthly)"
          },
          "dtstart": {
            "oneOf": [
              { "type": "null" },
              {
                "$ref": "#/$definitions/digest_field_config_string_def"
              }
            ],
            "description": "Schedule start datetime config (YYYY-MM-DDTHH:MM:SS)"
          },
          "is_default": {
            "type": "boolean",
            "description": "Whether this option is the default selection"
          }
        },
        "required": ["label", "frequency"],
        "additionalProperties": true
      },
      "digest_field_config_string_def": {
        "type": "object",
        "description": "DigestSchedule Field Config of string type",
        "properties": {
          "edit_policy": {
            "type": "string",
            "enum": ["locked", "editable"],
            "description": "Whether the value can be overridden by end subscriber"
          },
          "default_value": {
            "type": "string",
            "description": "Default value for the field"
          }
        },
        "required": ["edit_policy", "default_value"],
        "additionalProperties": true
      },
      "digest_field_config_weekdays_def": {
        "type": "object",
        "description": "DigestSchedule Field Config for weekdays",
        "properties": {
          "edit_policy": {
            "type": "string",
            "enum": ["locked", "editable"],
            "description": "Whether the value can be overridden by end subscriber"
          },
          "default_value": {
            "type": "array",
            "description": "Default weekdays",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["su", "mo", "tu", "we", "th", "fr", "sa"]
            }
          }
        },
        "required": ["edit_policy", "default_value"],
        "additionalProperties": true
      },
      "digest_field_config_monthdays_def": {
        "type": "object",
        "description": "DigestSchedule Field Config for monthly frequency",
        "properties": {
          "edit_policy": {
            "type": "string",
            "enum": ["locked", "editable"],
            "description": "Whether the value can be overridden by end subscriber"
          },
          "default_value": {
            "type": "array",
            "description": "Default monthdays",
            "items": {
              "$ref": "#/$definitions/schedule_monthday_def"
            }
          }
        },
        "required": ["edit_policy", "default_value"],
        "additionalProperties": true
      },
      "schedule_monthday_def": {
        "type": "object",
        "description": "ScheduleMonthday",
        "properties": {
          "pos": {
            "type": "integer",
            "description": "Position within the month. Absolute day: [-31..-1] or [1..31]; relative to a weekday: [-5..-1] or [1..5]."
          },
          "day": {
            "type": "string",
            "description": "Weekday for relative positioning. Omit/empty for an absolute day-of-month.",
            "enum": ["su", "mo", "tu", "we", "th", "fr", "sa"]
          }
        },
        "required": ["pos"],
        "additionalProperties": true
      },
      "cat_property_def": {
        "type": "object",
        "description": "Category Property definition",
        "properties": {
          "key": {
            "type": "string",
            "description": "Property key. Must start with a letter or underscore and contain only letters, numbers, and underscores.",
            "maxLength": 64,
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
          },
          "label": {
            "type": ["string", "null"],
            "description": "Human-readable label",
            "maxLength": 256
          },
          "value_type": {
            "type": "string",
            "description": "Type of the Property value",
            "enum": [
              "integer",
              "string",
              "string_choice",
              "list_choice",
              "string_dynamic",
              "list_dynamic"
            ]
          },
          "choices": {
            "type": ["array", "null"],
            "description": "Allowed choices (required for string_choice/list_choice value types)",
            "maxItems": 10,
            "items": {
              "$ref": "#/$definitions/cat_property_choice_def"
            }
          },
          "dynamic_choices_key": {
            "type": ["string", "null"],
            "description": "key using which choices can be populated on client-side (only for string_dynamic/list_dynamic value types)"
          },
          "default_value": {
            "type": ["integer", "string", "array", "null"],
            "description": "Default value. integer for 'integer'; string for 'string'/'string_choice'; array of strings for 'list_choice'; null for dynamic types.",
            "items": {
              "type": "string"
            }
          },
          "is_optional": {
            "type": "boolean",
            "description": "Whether value is optional. if yes, null/empty is allowed as valid value"
          },
          "edit_policy": {
            "type": "string",
            "enum": ["locked", "editable"],
            "description": "Whether the value can be overridden by the end user"
          }
        },
        "required": ["key", "value_type", "edit_policy"],
        "additionalProperties": true
      },
      "cat_property_choice_def": {
        "type": "object",
        "description": "CategoryProperty Choices",
        "properties": {
          "label": {
            "type": "string",
            "description": "Choice label",
            "minLength": 1,
            "maxLength": 256
          },
          "value": {
            "type": "string",
            "description": "Choice value",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "required": ["label", "value"],
        "additionalProperties": true
      }
    }
}
