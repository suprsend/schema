{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schema.suprsend.com/template/v2/channel/androidpush_schema.json",
    "title": "Androidpush Channel Template",
    "description": "Schema for androidpush channel content validation",
    "$comment": "Androidpush Channel Template",
    "type": "object",
    "properties": {
        "$schema": {
            "title": "$Schema",
            "type": "string",
            "format": "uri",
            "default": "https://schema.suprsend.com/template/v2/channel/androidpush_schema.json"
        },
        "templating_language": {
            "title": "Templating Language",
            "type": "string",
            "const": "handlebars",
            "default": "handlebars"
        },
        "header": {
            "title": "Header",
            "type": "string",
            "description": "message title/header",
            "minLength": 1,
            "maxLength": 500
        },
        "body": {
            "title": "Body",
            "type": "string",
            "description": "message text/body",
            "minLength": 1,
            "maxLength": 4000
        },
        "subtext": {
            "title": "Subtext",
            "type": "string",
            "description": "subtext",
            "maxLength": 50
        },
        "icon_small": {
            "title": "Icon Small",
            "type": "string"
        },
        "icon_url": {
            "title": "Icon Url",
            "type": "string",
            "default": "{{$brand.logo}}"
        },
        "image_url": {
            "title": "Image Url",
            "type": "string"
        },
        "action_url": {
            "title": "Action Url",
            "type": "string",
            "description": "action url/deeplink"
        },
        "buttons": {
            "title": "Buttons",
            "type": "array",
            "items": {
                "$ref": "#/$defs/androidpush_button_def"
            },
            "maxItems": 3
        },
        "channel_show_badge": {
            "title": "Channel Show Badge",
            "type": "boolean",
            "default": true
        },
        "channel_sound": {
            "title": "Channel Sound",
            "type": "string"
        },
        "channel_lock_screen_visibility": {
            "title": "Channel Lock Screen Visibility",
            "type": "string",
            "default": "PUBLIC",
            "enum": [
                "PUBLIC",
                "PRIVATE",
                "SECRET"
            ]
        },
        "channel_importance": {
            "default": "DEFAULT",
            "title": "Channel Importance",
            "type": "string",
            "enum": [
                "HIGH",
                "LOW",
                "MAX",
                "MIN",
                "DEFAULT"
            ]
        },
        "priority": {
            "title": "Priority",
            "type": "string",
            "default": "DEFAULT",
            "enum": [
                "HIGH",
                "DEFAULT"
            ]
        },
        "color": {
            "title": "Color",
            "type": "string",
            "default": "{{$organization.primary_color}}"
        },
        "auto_cancel": {
            "title": "Auto Cancel",
            "type": "boolean",
            "default": true
        },
        "group": {
            "title": "Group",
            "type": "string"
        },
        "timeout_sec": {
            "title": "Timeout Sec",
            "type": "integer",
            "default": 0,
            "description": "timeout in seconds",
            "minimum": 0
        },
        "is_silent": {
            "title": "Is Silent",
            "type": "boolean",
            "default": false,
            "description": "silent push"
        },
        "is_sticky": {
            "title": "Is Sticky",
            "type": "boolean",
            "default": false,
            "description": "sticky notification"
        },
        "local_only": {
            "title": "Local Only",
            "type": "boolean",
            "default": true,
            "description": "Local notification only"
        },
        "extra_payload": {
            "title": "Extra Payload",
            "type": "object",
            "default": {},
            "description": "extra payload. dict of key-value pairs",
            "additionalProperties": {
                "type": "string"
            }
        }
    },
    "required": ["header", "body"],
    "$defs": {
        "androidpush_button_def": {
            "title": "androidpush_button_def",
            "type": "object",
            "properties": {
                "id": {
                    "title": "Id",
                    "type": "string"
                },
                "text": {
                    "title": "Text",
                    "type": "string",
                    "default": ""
                },
                "url": {
                    "title": "Url",
                    "type": "string"
                }
            },
            "required": ["text", "url"]
        }
    }
}
